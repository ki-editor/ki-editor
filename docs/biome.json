{
    "root": true,
    "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "**",
            "!!**/build",
            "!!**/node_modules",
            "!!**/dist",
            "!!**/.docusaurus",
            "!!**/static/recipes"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "correctness": {
                "noUnusedVariables": "error",
                "noUnusedImports": "error"
            },
            "complexity": {
                "noForEach": "off"
            },
            "a11y": {
                "useButtonType": "off",
                "useAltText": "off"
            },
            "suspicious": { "noArrayIndexKey": "off" }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double"
        }
    }
}
